# App
APP_ENV=dev
OUTPUT_DIR=storage/outputs
DEFAULT_MARKET=AFRICA
USE_REAL_APIS=true
VIDEO_POLL_INTERVAL_SEC=5
VIDEO_POLL_TIMEOUT_SEC=300

# DeepSeek (text models)
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# SiliconFlow Wan (video model)
SILICONFLOW_API_KEY=YOUR_SILICONFLOW_API_KEY
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
WAN_MODEL=Wan-AI/Wan2.2-I2V-A14B
WAN_TASK_TYPE=image-to-video
WAN_IMAGE_SIZE=1280x720
WAN_IMAGE=

# Optional: set API path when you are ready to call Wan generation endpoint.
# Example: /video/submit
SILICONFLOW_WAN_SUBMIT_PATH=/video/submit

# Optional: query path for polling async Wan task status.
# Example: /video/query
SILICONFLOW_WAN_QUERY_PATH=/video/status

# Auth（首次启动且无用户时，用以下变量创建管理员；密码勿提交 Git）
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRE_HOURS=24
AUTH_DB_PATH=storage/auth.db
ADMIN_USERNAME=
ADMIN_PASSWORD=
# 置于 Nginx 等可信反代后时设为 true，以正确记录 X-Forwarded-For
TRUST_PROXY_HEADERS=false
